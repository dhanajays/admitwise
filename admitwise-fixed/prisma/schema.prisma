datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// ── NextAuth.js Tables ────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Users & Roles ────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  username       String?   @unique
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  mobile         String?   @unique
  mobileVerified Boolean   @default(false)
  passwordHash   String?   @db.Text
  isSuspended    Boolean   @default(false)

  // Subscriptions & Limits
  currentPlan   String?   @default("free") // "free", "single", "premium", "elite"
  paymentStatus String?   @default("unpaid") // "paid", "unpaid", "refunded"
  profileLimit  Int       @default(0) // Predictor Profile Limit
  profilesUsed  Int       @default(0) // Predictor Profiles Used
  trackerProfileLimit  Int @default(0) // Tracker Profile Limit
  trackerProfilesUsed  Int @default(0) // Tracker Profiles Used
  purchasedAddons      Int @default(0)

  // Audit info
  lastLogin     DateTime?
  loginProvider String?   @default("credentials")
  isFirstGoogleSignup Boolean @default(false)
  ipAddress     String?
  device        String?

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  category       String?
  gender         String?
  homeUniversity String?
  dateOfBirth    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts                Account[]
  sessions                Session[]
  subscriptions           Subscription[]
  payments                Payment[]
  predictionProfiles      PredictionProfile[]
  trackerCategoryProfiles TrackerCategoryProfile[]
  predictionHistories     PredictionHistory[]
  activityLogs            ActivityLog[]
  datasets                Dataset[] @relation("UserDatasets")
  vacantSeatDatasets      VacantSeatDataset[] @relation("UserVacantSeatDatasets")
  allIndiaDatasets        AllIndiaDataset[] @relation("UserAllIndiaDatasets")
  preferenceGeneratorDatasets PreferenceGeneratorDataset[] @relation("UserPreferenceDatasets")
  preferenceGeneratorPurchases PreferenceGeneratorPurchase[]
  notifications           Notification[]
  userProfile             UserProfile?
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "Super Admin", "Manager", "Support Executive", "Counsellor", "Student"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "manage_users", "manage_datasets", "manage_cms", "view_logs", "run_prediction"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles Role[] @relation("RolePermissions")
}

// ── Subscriptions & Payments ──────────────────────────────────────────────────

model Plan {
  id           String   @id // e.g. "single", "premium", "elite"
  name         String
  price        Float
  description  String
  maxProfiles  Int
  features     String   @db.Text // JSON string representation of features array
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  planId             String
  maxProfiles        Int
  trackerMaxProfiles Int       @default(0)
  status             String    @default("active") // "active", "expired", "pending"
  activatedAt        DateTime  @default(now())
  expiresAt          DateTime?

  // CAP Round lock tracking for multiple single plan purchases
  selectedRound        String?
  isUsed               Boolean   @default(false)
  trackerSelectedRound String?
  trackerIsUsed        Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  planId          String?
  orderId         String    @unique
  paymentId       String?   @unique
  signature       String?
  amount          Float
  gst             Float     @default(0.0)
  status          String    @default("Pending") // "Pending", "Success", "Failed", "Refunded"
  errorMessage    String?
  refundId        String?
  refundedAt      DateTime?
  purchaseType    String    @default("plan") // "plan" or "addon"
  addonQuantity   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([planId])
}

// ── Prediction Engine Models ──────────────────────────────────────────────────

model PredictionProfile {
  id                String   @id @default(cuid())
  userId            String
  exam              String
  percentile        Float
  predictionType    String?  @default("mht-cet") // "mht-cet" or "all-india"
  examScores        String?  @db.Text           // JSON string for exams e.g. [{"exam":"JEE(Main)","percentile":98.5}]
  round             String?  @default("I")
  gender            String?  @default("Male")
  category          String?  @default("OPEN")
  homeUniversity    String?
  disability        Boolean  @default(false)
  defenseQuota      Boolean  @default(false)
  preferredBranches String?  @db.Text           // JSON string for list of preferred branches
  createdAt         DateTime @default(now())

  // New fields for unified subscription engine
  planId            String?
  isLocked          Boolean  @default(true)
  usageCount        Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PredictionHistory {
  id                String   @id @default(cuid())
  userId            String?
  studentName       String
  exam              String
  percentile        Float
  branch            String
  category          String
  closingPercentile Float
  closingRank       Float
  chance            String
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ── Datasets & Cutoffs ────────────────────────────────────────────────────────

model Dataset {
  id               String   @id @default(cuid())
  year             Int
  exam             String   // e.g. "MHT CET PCM"
  round            String   // e.g. "Round 1", "Round 2", "Round 3", "Round 4", "Spot Round", "Institute Level"
  uploadedByUserId String
  uploadedAt       DateTime @default(now())
  status           String   @default("Active") // "Active", "Inactive"
  rowCount         Int      @default(0)
  filePath         String?  @db.Text

  uploadedByUser User @relation("UserDatasets", fields: [uploadedByUserId], references: [id])
  cutoffs        Cutoff[]
  versions       DatasetVersion[]
}

model DatasetVersion {
  id          String   @id @default(cuid())
  datasetId   String
  version     Int      @default(1)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model Cutoff {
  id                String  @id @default(cuid())
  datasetId         String
  collegeCode       String
  collegeName       String
  branchCode        String
  branchName        String
  status            String
  homeUniversity    String
  seatSection       String
  stage             String  // "I" or "II" or round representation
  categoryCodeRaw   String
  category          String
  gender            String
  disability        String  // "Yes" | "No"
  defenseQuota      String  // "Yes" | "No"
  closingRank       Int
  closingPercentile Float

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([category, stage, gender, disability, defenseQuota])
}

// ── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String
  subject      String
  message      String   @db.Text
  status       String   @default("Pending") // "Pending", "Resolved"
  replyMessage String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── CMS & Settings ────────────────────────────────────────────────────────────

model WebsiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "hero", "about", "pricing", "contact", "faq", "testimonials", "footer", "social", "seo"
  value     String   @db.Text // JSON string representing the configurations
  updatedAt DateTime @updatedAt
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String?   // null means Announcement for all users
  type      String    // "Email", "Announcement", "PlanUpdate", "AdmissionUpdate", "Maintenance"
  subject   String
  message   String    @db.Text
  isSent    Boolean   @default(false)
  sentAt    DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Logging & Audits ──────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g. "USER_LOGIN", "DATASET_UPLOAD", "PLAN_UPGRADE", "PREDICTION_RUN", "CONTACT_SUBMIT"
  ipAddress String?
  device    String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String?
  email          String?
  mobile         String?
  gender         String?
  category       String?
  homeUniversity String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Vacant Seat Tracker Models ──────────────────────────────────────────────────

model VacantSeatDataset {
  id               String       @id @default(cuid())
  year             Int
  exam             String       // e.g. "MHT CET PCM"
  round            String       // e.g. "Round 1", "Round 2", "Round 3"
  uploadedByUserId String
  uploadedAt       DateTime     @default(now())
  status           String       @default("Active") // "Active", "Inactive"
  rowCount         Int          @default(0)
  filePath         String?      @db.Text

  uploadedByUser User         @relation("UserVacantSeatDatasets", fields: [uploadedByUserId], references: [id])
  vacantSeats    VacantSeat[]
}

model VacantSeat {
  id              String   @id @default(cuid())
  datasetId       String
  round           String
  instituteCode   String
  instituteName   String
  instituteType   String
  choiceCode      String
  courseName      String
  capSeats        Int
  msSeats         Int
  minoritySeats   Int
  allIndiaSeats   Int
  instituteSeats  Int
  orphanSeats     Int

  // Category columns
  openG           Int
  openL           Int
  scG             Int
  scL             Int
  stG             Int
  stL             Int
  vjdtG           Int
  vjdtL           Int
  ntbG            Int
  ntbL            Int
  ntcG            Int
  ntcL            Int
  ntdG            Int
  ntdL            Int
  obcG            Int
  obcL            Int
  sebcG           Int
  sebcL           Int
  pwdCommon       Int
  defCommon       Int
  ewsSeats        Int
  tfwsSeats       Int

  dataset VacantSeatDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model TrackerCategoryProfile {
  id        String   @id @default(cuid())
  userId    String
  exam      String
  round     String
  category  String
  createdAt DateTime @default(now())

  // New fields for unified subscription engine
  planId            String?
  isLocked          Boolean  @default(true)
  usageCount        Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exam, round, category])
}

model AllIndiaDataset {
  id               String            @id @default(cuid())
  year             Int
  round            String            // "Round I", "Round II", "Round III", "Round IV"
  uploadedByUserId String
  uploadedAt       DateTime          @default(now())
  status           String            @default("Active") // "Active", "Inactive"
  rowCount         Int               @default(0)
  filePath         String?           @db.Text

  uploadedByUser   User              @relation("UserAllIndiaDatasets", fields: [uploadedByUserId], references: [id])
  cutoffs          AllIndiaCutoff[]
}

model AllIndiaCutoff {
  id                    String          @id @default(cuid())
  datasetId             String
  round                 String          // "Round I", "Round II", "Round III", "Round IV"
  instituteCode         String
  instituteName         String
  choiceCode            String
  courseName            String
  meritExam             String          // "JEE(Main)", "MHT-CET", "NEET"
  admissionType         String
  seatType              String
  closingAllIndiaMerit  Int
  closingPercentile     Float
  gender                String
  category              String
  pwd                   String          // "Yes" | "No"
  defense               String          // "Yes" | "No"
  homeUniversity        String
  availableForAllIndia  String          // "Yes" | "No"

  dataset               AllIndiaDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([meritExam, round, category, gender, pwd, defense])
}

// ── Preference List Generator Models ─────────────────────────────────────────

model PreferenceGeneratorDataset {
  id               String   @id @default(cuid())
  exam             String   @default("MHT CET PCM") // "MHT CET PCM"
  round            String   // "Round 1", "Round 2", "Round 3", "Round 4"
  uploadedByUserId String
  uploadedAt       DateTime @default(now())
  status           String   @default("Active") // "Active", "Inactive"
  rowCount         Int      @default(0)
  version          Int      @default(1)
  filePath         String?  @db.Text

  uploadedByUser   User                      @relation("UserPreferenceDatasets", fields: [uploadedByUserId], references: [id])
  cutoffs          PreferenceCutoff[]
  versions         PreferenceDatasetVersion[]

  @@unique([exam, round, status])
}

model PreferenceDatasetVersion {
  id               String   @id @default(cuid())
  datasetId        String
  version          Int      @default(1)
  rowCount         Int      @default(0)
  uploadedByUserId String
  createdAt        DateTime @default(now())

  dataset PreferenceGeneratorDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model PreferenceCutoff {
  id                String  @id @default(cuid())
  datasetId         String
  round             String  // "Round 1", "Round 2", "Round 3", "Round 4"
  collegeCode       String
  collegeName       String
  branchCode        String
  branchName        String
  status            String
  homeUniversity    String
  seatSection       String
  stage             String
  categoryCodeRaw   String  // e.g. "GOPENS", "LOPENS"
  gender            String
  disability        String  // "Yes" | "No"
  defenseQuota      String  // "Yes" | "No"
  closingRank       Int
  closingPercentile Float
  city              String

  dataset PreferenceGeneratorDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([round, categoryCodeRaw, closingPercentile])
  @@index([datasetId])
}

model PreferenceGeneratorPurchase {
  id              String   @id @default(cuid())
  userId          String
  round           String   // "Round 1", "Round 2", "Round 3", "Round 4"
  savedPercentile Float
  paymentId       String?
  amount          Float    @default(599)
  status          String   @default("Paid") // "Paid", "Pending", "Failed"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, round])
}