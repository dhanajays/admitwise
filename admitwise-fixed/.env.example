# Database connection URL (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/admitwise?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/admitwise?sslmode=require"

# NextAuth config
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_minimum_32_characters"

# Development Bypass Mode (set to "true" to bypass OTP / auto-verify email)
AUTH_BYPASS="true"

# Google OAuth Credentials (optional for dev, required for production Google login)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Supabase Credentials
NEXT_PUBLIC_SUPABASE_URL="https://your_project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Razorpay Credentials (required for payments/add-ons)
RAZORPAY_KEY_ID="rzp_live_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_if_any"
RAZORPAY_WEBHOOK_ALLOW_MOCK="false"

# Nodemailer SMTP Configuration (for contact form replies and notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_FROM="AdmitWise Support <your_email@gmail.com>"
